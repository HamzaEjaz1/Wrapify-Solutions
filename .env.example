# =============================================================================
# IMPORTANT: Next.js does NOT load this file.
# Copy what you need into a new file named:  .env.local
# (same folder as package.json). Then restart: npm run dev
# =============================================================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=wrapifysolutions@gmail.com
SMTP_PASS=your-smtp-password-here
SMTP_FROM=wrapifysolutions@gmail.com

# Public site URL for sitemap, canonical URLs, and structured data (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.wrapifysolutions.com

# Admin login for /blog/login and /admin — put this line in .env.local (not in this example file).
# If ADMIN_BLOG_TOKEN is missing in .env.local, dev fallback password is: wrapify-admin
ADMIN_BLOG_TOKEN=your-secret-here









